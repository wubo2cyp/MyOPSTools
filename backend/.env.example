# --- Server ---
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,agent_backend=debug

# --- Database ---
DATABASE_URL=sqlite://data/agent.db

# --- CORS ---
# Comma-separated list. Use "*" to allow all (NOT recommended for production).
CORS_ALLOW_ORIGIN=http://localhost:5173

# --- Model Provider (optional) ---
# Leave OPENAI_API_KEY empty to use the in-process Mock provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
