# --- Server ---
# Address the backend HTTP server binds to.
BIND_ADDR=0.0.0.0:8080
# Log filter (tracing-subscriber EnvFilter syntax).
RUST_LOG=info,agent_backend=debug,sqlx=warn

# --- Database ---
# sqlx URL. Default points at a local SQLite file under backend/data/.
DATABASE_URL=sqlite://data/agent.db
# Optional: disable the startup migration runner (default false).
RUN_MIGRATIONS=true

# --- CORS ---
# Comma-separated list of allowed origins. Use "*" to allow all (NOT recommended for production).
CORS_ALLOW_ORIGIN=http://localhost:5173

# --- Model Provider ---
# OpenAI-compatible chat completions endpoint. Leave OPENAI_API_KEY empty to
# fall back to the in-process Mock provider (useful for offline development).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Per-run temperature passed to the model provider (0.0–2.0, leave empty for provider default).
OPENAI_TEMPERATURE=

# --- Agent Behaviour ---
# System prompt prepended to every conversation.
AGENT_SYSTEM_PROMPT=你是一个轻量级通用 Agent，可以调用工具完成任务。请使用中文回答。
# Max tool-call iterations per run (safety guard against runaway loops).
AGENT_MAX_TOOL_CALLS=10
# Per-tool execution timeout in milliseconds.
AGENT_TOOL_TIMEOUT_MS=30000
# Auto-generate a title for a session from the first user message (uses the model).
AGENT_AUTO_TITLE=true
